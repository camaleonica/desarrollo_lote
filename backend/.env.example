# Server
PORT=3006
NODE_ENV=development

# Database (XAMPP local / Render external MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lote_db

# JWT
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_REFRESH_SECRET=otro_secreto_diferente_y_largo_aqui
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS (mobile + Render). Separar por coma en producción.
ALLOWED_ORIGINS=*

# KYC: false = verificación manual por empleado (consigna TPO). true = auto-aprueba en dev.
AUTO_APPROVE_KYC=false

# Admin backoffice (header X-Admin-Key)
ADMIN_API_KEY=cambia_esta_clave_admin

# Email — Gmail (recomendado para desarrollo)
# 1) Activá verificación en 2 pasos: https://myaccount.google.com/security
# 2) Creá "Contraseña de aplicación" → Correo → Dispositivo "Otro (Loté)"
# 3) Copiá los 16 caracteres (sin espacios) en SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=tu_correo@gmail.com
APP_PUBLIC_URL=http://localhost:3006

# Probar: npm run test:email
# Sin SMTP_HOST/SMTP_USER → los mails solo aparecen en la consola del backend

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
